{
  "name": "devinsight",
  "workspaces": [
    "packages/*"
  ],
  "version": "0.1.0",
  "description": "a repo analyzer",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "clean": "rimraf .next",
    "build": "prisma generate && next build",
    "start": "next start",
    "check-types": "tsc --noEmit --pretty",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/google": "^2.0.76",
    "@devinsight/core": "workspace:*",
    "@openrouter/sdk": "^0.13.7",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "ai": "^5.0.204",
    "better-auth": "^1.6.20",
    "dotenv": "^17.4.2",
    "geist": "^1.7.2",
    "next": "16.0.10",
    "octokit": "^5.0.5",
    "pg": "^8.22.0",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.43",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.10.38",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.0.10",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  }
}
